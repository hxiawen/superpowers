#!/usr/bin/env bash
# Shared acceptance-order helpers for hooks.
# Version-level autotest/mocktest/devicetest[/figma-live-sync|codetofigma]: ONLY inside "## Acceptance status (hooks)" (exact H2, no variants).

first_match_line() {
  local keyword="$1"
  local file="$2"
  rg -ni -m 1 "$keyword" "$file" 2>/dev/null | awk -F: 'NR==1{print $1}'
}

json_escape() {
  local raw="${1:-}"
  raw="${raw//\\/\\\\}"
  raw="${raw//\"/\\\"}"
  raw="${raw//$'\n'/\\n}"
  raw="${raw//$'\r'/\\r}"
  raw="${raw//$'\t'/\\t}"
  printf '%s' "$raw"
}

emit_block_json() {
  local reason="$1"
  local status_fallback="${2:-false}"
  shift 2 || true
  local missing_fields=("$@")
  local fields_json=""
  local field
  if [ "${#missing_fields[@]}" -gt 0 ]; then
    for field in "${missing_fields[@]}"; do
      if [ -n "$field" ]; then
        if [ -n "$fields_json" ]; then
          fields_json="${fields_json},"
        fi
        fields_json="${fields_json}\"$(json_escape "$field")\""
      fi
    done
  fi
  printf '{"decision":"block","reason":"%s","missing_fields":[%s],"status_fallback":%s}\n' "$(json_escape "$reason")" "$fields_json" "$status_fallback"
}

emit_block_json_with_meta() {
  local reason="$1"
  local status_fallback="${2:-false}"
  local remediation_owner="${3:-agent}"
  local block_class="${4:-agent_remediation_required}"
  local next_step="${5:-agent_fix_and_retry_stop_gate}"
  shift 5 || true
  local missing_fields=("$@")
  local fields_json=""
  local field
  if [ "${#missing_fields[@]}" -gt 0 ]; then
    for field in "${missing_fields[@]}"; do
      if [ -n "$field" ]; then
        if [ -n "$fields_json" ]; then
          fields_json="${fields_json},"
        fi
        fields_json="${fields_json}\"$(json_escape "$field")\""
      fi
    done
  fi
  printf '{"decision":"block","reason":"%s","missing_fields":[%s],"status_fallback":%s,"remediation_owner":"%s","block_class":"%s","next_step":"%s"}\n' \
    "$(json_escape "$reason")" \
    "$fields_json" \
    "$status_fallback" \
    "$(json_escape "$remediation_owner")" \
    "$(json_escape "$block_class")" \
    "$(json_escape "$next_step")"
}

user_confirmation_block_state_file() {
  local project_dir="${CLAUDE_PROJECT_DIR:-}"
  if [ -z "$project_dir" ]; then
    return 1
  fi
  printf '%s/.claude/.last-user-confirmation-block' "$project_dir"
}

remember_user_confirmation_block() {
  local block_key="$1"
  local state_file
  state_file="$(user_confirmation_block_state_file 2>/dev/null || true)"
  if [ -n "$state_file" ]; then
    mkdir -p "$(dirname "$state_file")"
    printf '%s\n' "$block_key" > "$state_file"
  fi
}

user_confirmation_block_already_prompted() {
  local block_key="$1"
  local state_file
  local previous_key=""
  state_file="$(user_confirmation_block_state_file 2>/dev/null || true)"
  if [ -z "$state_file" ] || [ ! -f "$state_file" ]; then
    return 1
  fi
  previous_key="$(tr -d '[:space:]' < "$state_file" 2>/dev/null || true)"
  [ "$previous_key" = "$block_key" ]
}

clear_user_confirmation_block_state() {
  local state_file
  state_file="$(user_confirmation_block_state_file 2>/dev/null || true)"
  if [ -n "$state_file" ]; then
    rm -f "$state_file"
  fi
}

# Semantic version label from a docs/* directory basename: V0.1.0-topic, pv0.1.0-topic, wv0.1.0-topic.
version_semantic_prefix_from_basename() {
  printf '%s' "$1" | sed -E 's/^([a-zA-Z]*[Vv][0-9]+\.[0-9]+\.[0-9]+).*/\1/'
}

superpowers_platform_release_marker_path() {
  printf '%s/.superpowers/platform-release' "${1:-}"
}

# Repo / platform-only release (e.g. chatbobi/vX.Y.Z): no docs/{prefix}v* version root; use docs/platform-release-test.md.
superpowers_platform_release_active() {
  local project_dir="$1"
  [ -n "$project_dir" ] && [ -f "$(superpowers_platform_release_marker_path "$project_dir")" ]
}

superpowers_platform_version_test_path() {
  printf '%s/docs/platform-release-test.md' "${1:-}"
}

# Exact H2 only (per docs/version-test-template); no i18n variants.
extract_acceptance_status_to_file() {
  local file="$1"
  local out="$2"
  if ! rg -q '^## Acceptance status \(hooks\)$' "$file" 2>/dev/null; then
    return 1
  fi
  awk '/^## Acceptance status \(hooks\)$/{flag=1;next} flag && /^## /{exit} flag' "$file" > "$out"
  return 0
}

# Validate autotest -> mocktest -> devicetest [-> figma-live-sync] order using first match **inside** "## Acceptance status (hooks)" only.
# Optional 4th param: design_sync_required="true" to enforce a design-sync status as 4th step (new: figma-live-sync; legacy: codetofigma).
validate_order_in_acceptance_section() {
  local file="$1"
  local scope="$2"
  local status_fallback="${3:-false}"
  local design_sync_required="${4:-false}"
  local tmp
  local auto_line
  local mock_line
  local device_line
  local design_sync_line
  tmp=$(mktemp)
  if ! extract_acceptance_status_to_file "$file" "$tmp"; then
    rm -f "$tmp"
    emit_block_json "${scope} 缺少「## Acceptance status (hooks)」小节（标题须逐字一致，见 version-test-template）。" "$status_fallback"
    return 1
  fi
  # Status tokens: English + 中文 + waived (N/A…) for no-extension versions
  auto_line="$(first_match_line "autotest[[:space:]:：-]*${ACCEPTANCE_STATUS_ORDER_TOKENS}" "$tmp")"
  mock_line="$(first_match_line "mocktest[[:space:]:：-]*${ACCEPTANCE_STATUS_ORDER_TOKENS}" "$tmp")"
  device_line="$(first_match_line "devicetest[[:space:]:：-]*${ACCEPTANCE_STATUS_ORDER_TOKENS}" "$tmp")"
  design_sync_line=""
  if [ "$design_sync_required" = "true" ]; then
    design_sync_line="$(first_match_line "(figma-live-sync|figma_live_sync|figma live sync|codetofigma)[[:space:]:：-]*${ACCEPTANCE_STATUS_ORDER_TOKENS}" "$tmp")"
  fi
  rm -f "$tmp"

  if [ -z "$auto_line" ] || [ -z "$mock_line" ] || [ -z "$device_line" ]; then
    emit_block_json "${scope} 在「## Acceptance status (hooks)」小节内缺少 autotest/mocktest/devicetest 的带状态结果行。" "$status_fallback"
    return 1
  fi

  if [ "$auto_line" -ge "$mock_line" ] || [ "$mock_line" -ge "$device_line" ]; then
    emit_block_json "${scope} 小节内测试顺序须为 autotest -> mocktest -> devicetest（按首次匹配行号）。" "$status_fallback"
    return 1
  fi

  if [ "$design_sync_required" = "true" ]; then
    if [ -z "$design_sync_line" ]; then
      emit_block_json "${scope} 在「## Acceptance status (hooks)」小节内缺少 figma-live-sync 的带状态结果行（plan 中包含 Figma Live Design Sync / Design Sync PR；legacy codetofigma 也兼容）。" "$status_fallback"
      return 1
    fi
    if [ "$device_line" -ge "$design_sync_line" ]; then
      emit_block_json "${scope} 小节内测试顺序须为 autotest -> mocktest -> devicetest -> figma-live-sync（legacy codetofigma 兼容；按首次匹配行号）。" "$status_fallback"
      return 1
    fi
  fi
  return 0
}

# Machine tokens inside "## Acceptance status (hooks)" (validate_order + keyword probes).
# Includes waived markers for web-only / no-extension versions (EP-004 follow-up).
ACCEPTANCE_STATUS_ORDER_TOKENS='(pass|fail|blocked|skip|pending|green|red|通过|失败|阻塞|跳过|待定|N/A|n/a|not[[:space:]]+applicable|不适用|无需)'

# Stages considered "settled" for next_expected (excludes pending; includes waived).
ACCEPTANCE_STATUS_NON_PENDING_TOKENS='(pass|fail|blocked|skip|green|red|通过|失败|阻塞|跳过|N/A|n/a|not[[:space:]]+applicable|不适用|无需)'

has_acceptance_status_keyword() {
  local keyword="$1"
  local file="$2"
  local status_pattern
  status_pattern="${keyword}[[:space:]:：-]*${ACCEPTANCE_STATUS_ORDER_TOKENS}"
  rg -qi "$status_pattern" "$file"
}

has_completed_acceptance_status_keyword() {
  local keyword="$1"
  local file="$2"
  local status_pattern
  status_pattern="${keyword}[[:space:]:：-]*${ACCEPTANCE_STATUS_NON_PENDING_TOKENS}"
  rg -qi "$status_pattern" "$file"
}

# next_expected: only ## Acceptance status (hooks) body. Returns missing_heading if H2 absent.
# Optional 2nd param: design_sync_required="true" to add figma-live-sync/codetofigma as 4th stage.
next_expected_test_from_version() {
  local version_test="$1"
  local design_sync_required="${2:-false}"
  local tmp
  tmp=$(mktemp)
  if ! extract_acceptance_status_to_file "$version_test" "$tmp"; then
    rm -f "$tmp"
    printf 'missing_heading'
    return 0
  fi

  if has_completed_acceptance_status_keyword "autotest" "$tmp" && \
     has_completed_acceptance_status_keyword "mocktest" "$tmp" && \
     has_completed_acceptance_status_keyword "devicetest" "$tmp"; then
    if [ "$design_sync_required" = "true" ]; then
      if has_completed_acceptance_status_keyword "figma-live-sync" "$tmp" || \
         has_completed_acceptance_status_keyword "figma_live_sync" "$tmp" || \
         has_completed_acceptance_status_keyword "codetofigma" "$tmp"; then
        rm -f "$tmp"
        printf 'done'
        return 0
      else
        rm -f "$tmp"
        printf 'figma-live-sync'
        return 0
      fi
    else
      rm -f "$tmp"
      printf 'done'
      return 0
    fi
  fi

  if has_completed_acceptance_status_keyword "autotest" "$tmp" && has_completed_acceptance_status_keyword "mocktest" "$tmp"; then
    rm -f "$tmp"
    printf 'devicetest'
    return 0
  fi

  if has_completed_acceptance_status_keyword "autotest" "$tmp"; then
    rm -f "$tmp"
    printf 'mocktest'
    return 0
  fi

  rm -f "$tmp"
  printf 'autotest'
}

# Backwards-compatible alias: historically scanned a whole file; now identical to
# validate_order_in_acceptance_section (## Acceptance status (hooks) … next ## only).
validate_order_in_file() {
  local file="$1"
  local scope="$2"
  local status_fallback="${3:-false}"
  local design_sync_required="${4:-false}"
  validate_order_in_acceptance_section "$file" "$scope" "$status_fallback" "$design_sync_required"
}

require_pattern_in_file() {
  local file="$1"
  local pattern="$2"
  local reason="$3"
  local status_fallback="${4:-false}"
  if ! rg -qi "$pattern" "$file"; then
    emit_block_json "$reason" "$status_fallback"
    return 1
  fi
  return 0
}

has_case_id_in_file() {
  local file="$1"
  rg -q "\\b(T|TC)-[0-9]{3}\\b" "$file"
}

# True when the value after autotest:/mocktest:/devicetest: means extension env tests were not run
# and no manifest build version needs to be echoed (build-version-report-guard).
acceptance_status_value_is_manifest_waived() {
  local raw="$1"
  local v lower
  v="$(printf '%s' "$raw" | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')"
  if [ -z "$v" ]; then
    return 1
  fi
  lower="$(printf '%s' "$v" | tr '[:upper:]' '[:lower:]')"
  case "$lower" in
    n/a|n/a*|not\ applicable|not\ applicable*) return 0 ;;
    不适用*|无需*) return 0 ;;
    skip|skip*) return 0 ;;
    跳过|跳过*) return 0 ;;
  esac
  if [ "$lower" = "na" ]; then
    return 0
  fi
  return 1
}

acceptance_env_triple_waived_no_manifest_version_report() {
  local version_test="$1"
  local tmp kw val
  tmp=$(mktemp)
  if ! extract_acceptance_status_to_file "$version_test" "$tmp"; then
    rm -f "$tmp"
    return 1
  fi
  for kw in autotest mocktest devicetest; do
    val="$(rg -i -m 1 -or '$1' "^[[:space:]]*[-*]?[[:space:]]*${kw}[[:space:]:：-]+(.+)$" "$tmp" 2>/dev/null || true)"
    if [ -z "$val" ]; then
      rm -f "$tmp"
      return 1
    fi
    if ! acceptance_status_value_is_manifest_waived "$val"; then
      rm -f "$tmp"
      return 1
    fi
  done
  rm -f "$tmp"
  return 0
}

# Platform / repo-only releases: structure -> build -> git-history inside "## Acceptance status (hooks)".
validate_platform_acceptance_section() {
  local file="$1"
  local scope="$2"
  local status_fallback="${3:-false}"
  local tmp str_line build_line git_line
  tmp=$(mktemp)
  if ! extract_acceptance_status_to_file "$file" "$tmp"; then
    rm -f "$tmp"
    emit_block_json "${scope} 缺少「## Acceptance status (hooks)」小节（标题须逐字一致，见 platform-version-test-template）。" "$status_fallback"
    return 1
  fi
  str_line="$(first_match_line "structure[[:space:]:：-]*${ACCEPTANCE_STATUS_ORDER_TOKENS}" "$tmp")"
  build_line="$(first_match_line "^[[:space:]]*[-*]?[[:space:]]*build[[:space:]:：-]*${ACCEPTANCE_STATUS_ORDER_TOKENS}" "$tmp")"
  git_line="$(first_match_line "(git-history|git_history)[[:space:]:：-]*${ACCEPTANCE_STATUS_ORDER_TOKENS}" "$tmp")"
  rm -f "$tmp"
  if [ -z "$str_line" ] || [ -z "$build_line" ] || [ -z "$git_line" ]; then
    emit_block_json "${scope} 在「## Acceptance status (hooks)」内缺少 structure / build / git-history 的带状态结果行（平台版本，见 platform-version-test-template）。" "$status_fallback"
    return 1
  fi
  if [ "$str_line" -ge "$build_line" ] || [ "$build_line" -ge "$git_line" ]; then
    emit_block_json "${scope} 平台验收顺序须为 structure -> build -> git-history（按首次匹配行号）。" "$status_fallback"
    return 1
  fi
  return 0
}

# Path depth under docs/: docs/pv0.1.0-t/ => 1; docs/plugin/pv0.1.0-t/ => 2 (ChatBobi v0.1.14+ nests product segment).
_docs_semantic_version_rel_depth() {
  local docs_root="${1%/}"
  local path="${2%/}"
  local rel="${path#"${docs_root}/}"}"
  printf '%s' "$rel" | awk -F/ '{print NF}'
}

resolve_latest_version_dir() {
  local project_dir="$1"
  local docs="$project_dir/docs"
  if [ ! -d "$docs" ]; then
    printf ''
    return 0
  fi
  # Version roots: docs/<semantic>/ OR docs/<product>/<semantic>/ (same basename → prefer deeper path).
  local -a raw=()
  local d base parent
  shopt -s nullglob
  for d in "$docs"/*/; do
    [ -d "$d" ] || continue
    base="$(basename "${d%/}")"
    if printf '%s' "$base" | rg -q '^[a-zA-Z]*[vV][0-9]+\.[0-9]+\.[0-9]+-'; then
      raw+=("${d%/}")
    fi
  done
  for d in "$docs"/*/*/; do
    [ -d "$d" ] || continue
    parent="$(basename "$(dirname "${d%/}")")"
    # Skip docs/<versionDir>/… (e.g. PR dirs): second segment must be under a non-version product folder.
    if printf '%s' "$parent" | rg -q '^[a-zA-Z]*[vV][0-9]+\.[0-9]+\.[0-9]+-'; then
      continue
    fi
    base="$(basename "${d%/}")"
    if printf '%s' "$base" | rg -q '^[a-zA-Z]*[vV][0-9]+\.[0-9]+\.[0-9]+-'; then
      raw+=("${d%/}")
    fi
  done
  shopt -u nullglob
  if [ "${#raw[@]}" -eq 0 ]; then
    printf ''
    return 0
  fi
  local -a matches=()
  local i j bi bj di dj keep
  for i in "${!raw[@]}"; do
    keep=1
    bi="$(basename "${raw[i]}")"
    di="$(_docs_semantic_version_rel_depth "$docs" "${raw[i]}")"
    for j in "${!raw[@]}"; do
      [ "$i" -eq "$j" ] && continue
      bj="$(basename "${raw[j]}")"
      [ "$bi" = "$bj" ] || continue
      dj="$(_docs_semantic_version_rel_depth "$docs" "${raw[j]}")"
      if [ "$dj" -gt "$di" ]; then
        keep=0
        break
      fi
    done
    [ "$keep" = 1 ] && matches+=("${raw[i]}")
  done
  if [ "${#matches[@]}" -eq 0 ]; then
    printf ''
    return 0
  fi
  local out
  out=$(ls -dt "${matches[@]}" | rg '/docs/([^/]+/)?[a-zA-Z]*[vV][0-9]+\.[0-9]+\.[0-9]+-' | awk 'NR==1{print;exit}') || return $?
  printf '%s' "$out"
  return 0
}

# Map feat/{prefix}vX.Y.Z-topic branch to docs version root (basename aligns with branch suffix).
# feat/v0.1.0-a / feat/pv0.1.9-b / feat/chatbobi-v0.1.14-c supported; empty if not a feature branch or no matching dir.
resolve_version_dir_from_branch() {
  local project_dir="$1"
  local branch="$2"
  if ! printf '%s' "$branch" | rg -q '^feat/[a-zA-Z]*[vV][0-9]+\.[0-9]+\.[0-9]+-'; then
    printf ''
    return 0
  fi

  local suffix docs_dir suffix_lc
  suffix="${branch#feat/}"
  docs_dir="$project_dir/docs"
  if [ ! -d "$docs_dir" ]; then
    printf ''
    return 0
  fi

  suffix_lc="$(printf '%s' "$suffix" | tr '[:upper:]' '[:lower:]')"
  local d base b_lc parent
  local -a hits=()
  local -a hitdepth=()
  shopt -s nullglob
  for d in "$docs_dir"/*/; do
    [ -d "$d" ] || continue
    base="$(basename "${d%/}")"
    if ! printf '%s' "$base" | rg -q '^[a-zA-Z]*[vV][0-9]+\.[0-9]+\.[0-9]+-'; then
      continue
    fi
    b_lc="$(printf '%s' "$base" | tr '[:upper:]' '[:lower:]')"
    if [ "$b_lc" = "$suffix_lc" ]; then
      hits+=("${d%/}")
      hitdepth+=("$(_docs_semantic_version_rel_depth "$docs_dir" "${d%/}")")
    fi
  done
  for d in "$docs_dir"/*/*/; do
    [ -d "$d" ] || continue
    parent="$(basename "$(dirname "${d%/}")")"
    if printf '%s' "$parent" | rg -q '^[a-zA-Z]*[vV][0-9]+\.[0-9]+\.[0-9]+-'; then
      continue
    fi
    base="$(basename "${d%/}")"
    if ! printf '%s' "$base" | rg -q '^[a-zA-Z]*[vV][0-9]+\.[0-9]+\.[0-9]+-'; then
      continue
    fi
    b_lc="$(printf '%s' "$base" | tr '[:upper:]' '[:lower:]')"
    if [ "$b_lc" = "$suffix_lc" ]; then
      hits+=("${d%/}")
      hitdepth+=("$(_docs_semantic_version_rel_depth "$docs_dir" "${d%/}")")
    fi
  done
  shopt -u nullglob
  if [ "${#hits[@]}" -eq 0 ]; then
    printf ''
    return 0
  fi
  local best_i=0
  local i
  for i in "${!hits[@]}"; do
    if [ "${hitdepth[$i]}" -gt "${hitdepth[$best_i]}" ]; then
      best_i="$i"
    fi
  done
  printf '%s' "${hits[$best_i]}"
  return 0
}

# feat/pv0.1.14-hotfix-scroll — published-version emergency fix (project2feedback No.18).
is_hotfix_branch() {
  local branch="${1:-}"
  [ -n "$branch" ] && printf '%s' "$branch" | rg -q '^feat/[a-zA-Z]*[vV][0-9]+\.[0-9]+\.[0-9]+-hotfix-'
}

# docs/plugin/pv0.1.14-hotfix-scroll — same -hotfix- topic suffix on version doc root.
is_hotfix_version_basename() {
  local base="${1:-}"
  [ -n "$base" ] && printf '%s' "$base" | rg -q '^[a-zA-Z]*[vV][0-9]+\.[0-9]+\.[0-9]+-hotfix-'
}

is_hotfix_version_dir() {
  local version_dir="${1:-}"
  [ -n "$version_dir" ] && is_hotfix_version_basename "$(basename "${version_dir%/}")"
}

# Prefer branch-bound docs root (feat/...-hotfix-... → docs/.../pv*-hotfix-...); else latest by mtime.
resolve_active_version_dir() {
  local project_dir="$1"
  local branch="${2:-}"
  if [ -z "$branch" ] && git -C "$project_dir" rev-parse --git-dir >/dev/null 2>&1; then
    branch="$(git -C "$project_dir" branch --show-current 2>/dev/null || true)"
  fi
  local from_branch=""
  if [ -n "$branch" ]; then
    from_branch="$(resolve_version_dir_from_branch "$project_dir" "$branch")"
  fi
  if [ -n "$from_branch" ]; then
    printf '%s' "$from_branch"
    return 0
  fi
  resolve_latest_version_dir "$project_dir"
}

# Sub-product release tag for plugin/webapp (plugin/pv0.1.14, webapp/wv0.1.3, hotfix plugin/pv0.1.14-hf1).
subproduct_release_tag_from_version_dir() {
  local version_dir="${1:-}"
  local base product prefix
  [ -n "$version_dir" ] || return 1
  base="$(basename "${version_dir%/}")"
  if is_hotfix_version_basename "$base"; then
    prefix="$(version_semantic_prefix_from_basename "$base")"
    if printf '%s' "$version_dir" | rg -q '/docs/plugin/'; then
      product="plugin"
    elif printf '%s' "$version_dir" | rg -q '/docs/webapp/'; then
      product="webapp"
    else
      product="plugin"
    fi
    printf '%s/%s-hfN' "$product" "$prefix"
    return 0
  fi
  if printf '%s' "$base" | rg -q '^pv'; then
    printf 'plugin/%s' "$base"
    return 0
  fi
  if printf '%s' "$base" | rg -q '^wv'; then
    printf 'webapp/%s' "$base"
    return 0
  fi
  printf ''
  return 1
}

# x.y.z from feat/pv0.1.14-hotfix-scroll or feat/pv0.1.15-panel.
semver_triplet_from_feat_branch() {
  local branch="${1:-}"
  [ -n "$branch" ] || return 1
  if ! printf '%s' "$branch" | rg -q '^feat/[a-zA-Z]*[vV][0-9]+\.[0-9]+\.[0-9]+'; then
    return 1
  fi
  printf '%s' "$branch" | sed -E 's/^feat\/[a-zA-Z]*[vV]([0-9]+\.[0-9]+\.[0-9]+).*/\1/'
}

# Returns 0 iff triplet a is strictly greater than b (sort -V).
semver_triplet_gt() {
  local a="$1" b="$2"
  [ -n "$a" ] && [ -n "$b" ] || return 1
  [ "$a" != "$b" ] && [ "$(printf '%s\n%s\n' "$b" "$a" | sort -V | tail -1)" = "$a" ]
}

_git_integration_ref() {
  local project_dir="$1"
  local ref
  for ref in main master origin/main origin/master; do
    if git -C "$project_dir" rev-parse --verify "$ref" >/dev/null 2>&1; then
      printf '%s' "$ref"
      return 0
    fi
  done
  printf ''
  return 1
}

# 0 if branch has at least one commit not reachable from integration (main/master).
_git_branch_ahead_of_integration() {
  local project_dir="$1" branch="$2"
  local integration
  integration="$(_git_integration_ref "$project_dir")"
  [ -n "$integration" ] || return 1
  [ -n "$(git -C "$project_dir" log "${integration}..${branch}" --oneline 2>/dev/null | sed '/^[[:space:]]*$/d' | head -1)" ]
}

# plugin/pv0.1.14 from feat/pv0.1.14-hotfix-* ; webapp/wv0.1.3 from feat/wv0.1.3-hotfix-*.
subproduct_baseline_tag_from_hotfix_branch() {
  local branch="${1:-}"
  local product_ver
  if printf '%s' "$branch" | rg -q '^feat/pv[0-9]+\.[0-9]+\.[0-9]+'; then
    product_ver="$(printf '%s' "$branch" | sed -E 's/^feat\/(pv[0-9]+\.[0-9]+\.[0-9]+).*/\1/')"
    [ -n "$product_ver" ] && printf 'plugin/%s' "$product_ver"
    return 0
  fi
  if printf '%s' "$branch" | rg -q '^feat/wv[0-9]+\.[0-9]+\.[0-9]+'; then
    product_ver="$(printf '%s' "$branch" | sed -E 's/^feat\/(wv[0-9]+\.[0-9]+\.[0-9]+).*/\1/')"
    [ -n "$product_ver" ] && printf 'webapp/%s' "$product_ver"
    return 0
  fi
  printf ''
  return 1
}

# Local + remote feat/pv* branches: exclude hotfix, self, merged-into-main, and <= hotfix base semver.
list_in_flight_pv_feature_branches() {
  local project_dir="$1"
  local exclude_branch="${2:-}"
  local hotfix_base="" b_ver b
  if is_hotfix_branch "$exclude_branch"; then
    hotfix_base="$(semver_triplet_from_feat_branch "$exclude_branch" 2>/dev/null || true)"
  fi
  while IFS= read -r b; do
    [ -z "$b" ] && continue
    printf '%s' "$b" | rg -q '^feat/[a-zA-Z]*[vV][0-9]+\.[0-9]+\.[0-9]+-' || continue
    printf '%s' "$b" | rg -q 'hotfix-' && continue
    [ -n "$exclude_branch" ] && [ "$b" = "$exclude_branch" ] && continue
    if ! _git_branch_ahead_of_integration "$project_dir" "$b"; then
      continue
    fi
    if [ -n "$hotfix_base" ]; then
      b_ver="$(semver_triplet_from_feat_branch "$b" 2>/dev/null || true)"
      if [ -z "$b_ver" ] || ! semver_triplet_gt "$b_ver" "$hotfix_base"; then
        continue
      fi
    fi
    printf '%s\n' "$b"
  done < <(
    {
      git -C "$project_dir" for-each-ref --format='%(refname:short)' refs/heads 2>/dev/null || true
      git -C "$project_dir" for-each-ref --format='%(refname:short)' refs/remotes/origin 2>/dev/null | sed 's|^origin/||' || true
    } | sort -u
  )
}

# PR finalize-log parallel sync: off | plan (strategy+target) | full (+ non-placeholder evidence).
# Legacy second arg "true" maps to "full".
parallel_sync_section_valid() {
  local finalize_log="$1"
  local mode="${2:-off}"
  if [ "$mode" = "true" ]; then
    mode="full"
  elif [ "$mode" = "false" ]; then
    mode="off"
  fi
  [ -f "$finalize_log" ] || return 1
  if ! rg -q '^##[[:space:]]+Parallel next minor sync' "$finalize_log" 2>/dev/null; then
    return 1
  fi
  if [ "$mode" = "off" ]; then
    return 0
  fi
  if rg -qi '^[[:space:]]*[-*]?[[:space:]]*strategy:[[:space:]]*N/A' "$finalize_log"; then
    return 1
  fi
  if ! rg -qi 'strategy:[[:space:]]*(merge_main|cherry_pick)' "$finalize_log"; then
    return 1
  fi
  if [ "$mode" = "plan" ] || [ "$mode" = "full" ]; then
    if ! rg -qi 'target_branch:' "$finalize_log"; then
      return 1
    fi
  fi
  if [ "$mode" = "full" ]; then
    if ! rg -qi 'evidence:' "$finalize_log"; then
      return 1
    fi
    if rg -qi 'evidence:[[:space:]]*(TBD|pending|待补|占位|TODO)[[:space:]]*$' "$finalize_log"; then
      return 1
    fi
  fi
  return 0
}

# Check if version plan includes Figma Live Design Sync / Design Sync PR.
# Returns 0 if plan mentions new figma-live sync or legacy Design Sync/codetofigma, 1 otherwise.
plan_has_design_sync() {
  local version_dir="$1"
  local version_basename
  version_basename="$(basename "$version_dir")"
  local version_prefix
  version_prefix="$(version_semantic_prefix_from_basename "$version_basename")"
  local plan_file="${version_dir}/${version_prefix}-plan.md"
  if [ ! -f "$plan_file" ]; then
    return 1
  fi
  rg -qi '(Figma Live Design Sync|figma-live-sync|figma_live_sync|Design Sync|codetofigma)' "$plan_file"
}

# Machine-readable in Vx.y.z-spec.md under "## Superpowers pipeline (hooks)" (exact H2).
# Returns 0 iff the section declares extension/lab pipeline waived (No / 否).
# Missing section or Yes → returns 1 (full pipeline required; conservative).
superpowers_extension_pipeline_waived() {
  local project_dir="$1"
  local latest vprefix specfile section
  latest="$(resolve_latest_version_dir "$project_dir")"
  [ -n "$latest" ] || return 1
  vprefix="$(version_semantic_prefix_from_basename "$(basename "$latest")")"
  specfile="${latest}/${vprefix}-spec.md"
  [ -f "$specfile" ] || return 1
  if ! rg -q '^## Superpowers pipeline \(hooks\)$' "$specfile" 2>/dev/null; then
    return 1
  fi
  section="$(mktemp)"
  awk '/^## Superpowers pipeline \(hooks\)$/{p=1;next} p && /^## /{exit} p' "$specfile" >"$section"
  if ! rg -qi '^Full extension acceptance pipeline[[:space:]:：]*[[:space:]]*(no|n|false)([[:space:][:punct:]].*)?$' "$section" && \
     ! rg -qi '^完整扩展验收流程[[:space:]:：]*[[:space:]]*(否|不)([[:space:][:punct:]].*)?$' "$section"; then
    rm -f "$section"
    return 1
  fi
  rm -f "$section"
  return 0
}

# PR dir under version root: regular pv0.1.14-PRn or hotfix pv0.1.14-hotfix-topic-PRn.
_pr_dir_matches_version() {
  local version_dir="$1"
  local pr_basename="$2"
  local version_basename
  [ -n "$version_dir" ] && [ -n "$pr_basename" ] || return 1
  version_basename="$(basename "${version_dir%/}")"
  if is_hotfix_version_basename "$version_basename"; then
    case "$pr_basename" in
      "${version_basename}"-PR[0-9]*) return 0 ;;
    esac
    return 1
  fi
  printf '%s' "$pr_basename" | rg -q '^[a-zA-Z]*[vV][0-9]+\.[0-9]+\.[0-9]+-PR[0-9]+$'
}

# Collect PR directories under version_dir whose basename ends with -PRn and matches semantic version prefix.
_collect_semantic_pr_dirs() {
  local version_dir="$1"
  local pr_suffix="$2"
  local -a found=()
  local d b
  shopt -s nullglob
  for d in "$version_dir"/*/; do
    [ -d "$d" ] || continue
    b="$(basename "${d%/}")"
    case "$b" in *-"$pr_suffix") ;;
      *) continue ;;
    esac
    if _pr_dir_matches_version "$version_dir" "$b"; then
      found+=("${d%/}")
    fi
  done
  shopt -u nullglob
  if [ "${#found[@]}" -eq 0 ]; then
    printf ''
    return 0
  fi
  ls -dt "${found[@]}" | awk 'NR==1{print;exit}'
}

resolve_active_pr_dir() {
  local project_dir="$1"
  local version_dir="$2"
  local hint_text="${3:-}"
  local candidate=""
  local active_pr_name=""

  # Highest priority: explicit PR dir env override
  if [ -n "${SUPERPOWERS_ACTIVE_PR_DIR:-}" ] && [ -d "${SUPERPOWERS_ACTIVE_PR_DIR}" ]; then
    printf '%s' "${SUPERPOWERS_ACTIVE_PR_DIR}"
    return 0
  fi

  # Explicit PR basename override (e.g. V0.1.6-PR2)
  if [ -n "${SUPERPOWERS_ACTIVE_PR:-}" ] && [ -d "${version_dir}/${SUPERPOWERS_ACTIVE_PR}" ]; then
    printf '%s' "${version_dir}/${SUPERPOWERS_ACTIVE_PR}"
    return 0
  fi

  # Explicit active PR context alias (supports values like PR2 / V0.1.6-PR2)
  if [ -n "${SUPERPOWERS_ACTIVE_PR_CONTEXT:-}" ]; then
    active_pr_name="${SUPERPOWERS_ACTIVE_PR_CONTEXT}"
    if printf '%s' "$active_pr_name" | rg -q '^[Pp][Rr][0-9]+$'; then
      local _pr_suffix
      _pr_suffix="$(printf '%s' "$active_pr_name" | tr '[:lower:]' '[:upper:]')"
      candidate="$(_collect_semantic_pr_dirs "$version_dir" "$_pr_suffix")"
      if [ -n "$candidate" ]; then
        printf '%s' "$candidate"
        return 0
      fi
    elif [ -d "${version_dir}/${active_pr_name}" ]; then
      printf '%s' "${version_dir}/${active_pr_name}"
      return 0
    fi
  fi

  # Optional project-local active PR marker
  if [ -f "${project_dir}/.claude/.active-pr" ]; then
    local marker
    marker="$(tr -d '[:space:]' < "${project_dir}/.claude/.active-pr" 2>/dev/null || true)"
    if [ -n "$marker" ]; then
      if [ -d "$marker" ]; then
        printf '%s' "$marker"
        return 0
      fi
      if [ -d "${version_dir}/${marker}" ]; then
        printf '%s' "${version_dir}/${marker}"
        return 0
      fi
    fi
  fi

  # Prompt hint fallback: extract "PRn" from request text
  if [ -n "$hint_text" ]; then
    local hint_pr
    hint_pr="$(printf '%s' "$hint_text" | tr '[:upper:]' '[:lower:]' | rg -o 'pr[0-9]+' -m 1 2>/dev/null | tr '[:lower:]' '[:upper:]' || true)"
    if [ -n "$hint_pr" ]; then
      candidate="$(_collect_semantic_pr_dirs "$version_dir" "$hint_pr")"
      if [ -n "$candidate" ]; then
        printf '%s' "$candidate"
        return 0
      fi
    fi
  fi

  # Last fallback: latest PR directory under selected version
  if [ ! -d "$version_dir" ]; then
    printf ''
    return 0
  fi
  local -a prm=()
  local d b
  shopt -s nullglob
  for d in "$version_dir"/*/; do
    [ -d "$d" ] || continue
    b="$(basename "${d%/}")"
    if _pr_dir_matches_version "$version_dir" "$b"; then
      prm+=("${d%/}")
    fi
  done
  shopt -u nullglob
  if [ "${#prm[@]}" -eq 0 ]; then
    printf ''
    return 0
  fi
  local out
  out=$(ls -dt "${prm[@]}" | awk 'NR==1{print;exit}') || return $?
  printf '%s' "$out"
  return 0
}

# Extension publish integrity (No.19): git-tracked .output must include latest app/plugin source.
plugin_output_manifest_path() {
  printf '%s/app/plugin/.output/chrome-mv3/manifest.json' "${1:-}"
}

plugin_source_latest_commit() {
  local project_dir="$1"
  git -C "$project_dir" log -1 --format=%H -- app/plugin/ ':(exclude)app/plugin/.output' 2>/dev/null ||
    git -C "$project_dir" log -1 --format=%H -- app/plugin/ 2>/dev/null || true
}

plugin_output_latest_commit() {
  local project_dir="$1"
  git -C "$project_dir" log -1 --format=%H -- app/plugin/.output/ 2>/dev/null || true
}

plugin_output_covers_source_tip() {
  local project_dir="$1"
  local src_tip out_tip
  src_tip="$(plugin_source_latest_commit "$project_dir")"
  out_tip="$(plugin_output_latest_commit "$project_dir")"
  [ -n "$src_tip" ] || return 0
  [ -n "$out_tip" ] || return 1
  [ "$src_tip" = "$out_tip" ] && return 0
  git -C "$project_dir" merge-base --is-ancestor "$src_tip" "$out_tip" 2>/dev/null
}

plugin_manifest_base_matches_wxt() {
  local project_dir="$1"
  local manifest wxt base ver
  manifest="$(plugin_output_manifest_path "$project_dir")"
  wxt="${project_dir}/app/plugin/wxt.config.ts"
  [ -f "$manifest" ] || return 0
  [ -f "$wxt" ] || return 0
  base="$(rg -o "BASE_VERSION = '[^']+'" "$wxt" 2>/dev/null | sed -E "s/.*'([^']+)'.*/\\1/")"
  [ -n "$base" ] || return 0
  ver="$(rg -o '"version":"[0-9.]+"' "$manifest" 2>/dev/null | head -1 | sed -E 's/.*"version":"([^"]+)".*/\1/')"
  [ -z "$ver" ] && return 0
  [ "$ver" = "$base" ] || printf '%s' "$ver" | rg -q "^${base}\\."
}

_is_integration_branch() {
  local branch="${1:-}"
  case "$branch" in
    main|master) return 0 ;;
    *) return 1 ;;
  esac
}
