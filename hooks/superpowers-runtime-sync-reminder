#!/usr/bin/env bash
# UserPromptSubmit hook: inject routing guidance for superpowers maintenance tasks.

set -euo pipefail

INPUT="$(cat || true)"

extract_prompt() {
  local raw="$1"
  if command -v jq >/dev/null 2>&1; then
    local parsed
    parsed="$(printf '%s' "$raw" | jq -r '.prompt // .message // .text // .payload.prompt // .payload.message // .payload.text // empty' 2>/dev/null || true)"
    if [ -n "$parsed" ] && [ "$parsed" != "null" ]; then
      printf '%s' "$parsed"
      return
    fi
  fi
  printf ''
}

escape_for_json() {
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  s="${s//$'\n'/\\n}"
  s="${s//$'\r'/\\r}"
  s="${s//$'\t'/\\t}"
  printf '%s' "$s"
}

PROMPT="$(extract_prompt "$INPUT")"
if [ -z "$PROMPT" ]; then
  exit 0
fi

mentions_superpowers_surface() {
  local prompt="$1"
  printf '%s' "$prompt" | rg -qi "superpowers|runtime sync|runtime|hook|hooks|overlay|cache|fork|sync-superpowers-fork|manage-superpowers-local|docs/superpowers-local|plugin cache|claude plugin"
}

mentions_change_intent() {
  local prompt="$1"
  printf '%s' "$prompt" | rg -qi "改|修改|修|修复|实现|处理|补|加|新增|调整|优化|重构|部署|发版|release|deploy|sync|同步|push|tag|merge|合并|更新|维护"
}

if ! mentions_superpowers_surface "$PROMPT"; then
  exit 0
fi

if ! mentions_change_intent "$PROMPT"; then
  exit 0
fi

reminder="Superpowers maintenance task detected. Route this turn through Superpowers Runtime Sync. Source of truth order: (1) /Users/harry/Documents/GitHub/superpowers-fork for version-controlled changes, (2) docs/superpowers-local/ as overlay/deploy helper, (3) ~/.claude/plugins/cache/claude-plugins-official/superpowers/<version>/ as runtime target only. Preferred flow: edit/test in fork -> docs/scripts/sync-superpowers-fork.sh capture -> status -> deploy latest -> black-box verify -> update docs/superpowers-local/LOCAL_RELEASES.md -> commit/push/tag/changelogs in the fork. Do not treat ChatBobi overlay or installed cache as the primary editing location unless the user explicitly approves an emergency hotfix."
reminder_escaped="$(escape_for_json "$reminder")"

if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "additional_context": "%s"\n}\n' "$reminder_escaped"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -z "${COPILOT_CLI:-}" ]; then
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "UserPromptSubmit",\n    "additionalContext": "%s"\n  }\n}\n' "$reminder_escaped"
else
  printf '{\n  "additionalContext": "%s"\n}\n' "$reminder_escaped"
fi

exit 0
