#!/usr/bin/env bash
# SessionStart hook: check feedback index and remind evolution review

set -euo pipefail

HOOK_DIR="$(cd "$(dirname "$0")" && pwd)"
# shellcheck source=hooks/evolution-index-common
. "$HOOK_DIR/evolution-index-common"

if ! evo_load_index_stats; then
  exit 0
fi

# Only surface SessionStart noise when there are actionable candidates (occurrences + status).
if [ "${EVO_CANDIDATES:-0}" -gt 0 ] 2>/dev/null; then
  evo_write_required_marker
  reminder="$(evo_reminder_text)"
  reminder_escaped="$(evo_escape_for_json "$reminder")"

  if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
    printf '{\n  "additional_context": "%s"\n}\n' "$reminder_escaped"
  elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -z "${COPILOT_CLI:-}" ]; then
    printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$reminder_escaped"
  else
    printf '{\n  "additional_context": "%s"\n}\n' "$reminder_escaped"
  fi
else
  rm -f "${CLAUDE_PROJECT_DIR}/.claude/.evolution-required" 2>/dev/null || true
fi

exit 0
